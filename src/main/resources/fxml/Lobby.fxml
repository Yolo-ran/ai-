<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gesturegame.ui.LobbyController"
            style="-fx-background-color: black;">
    <children>
        <StackPane fx:id="rayLayer" mouseTransparent="true"
                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Canvas fx:id="rayCanvas" height="720.0" width="1280.0"
                        mouseTransparent="true" />
            </children>
        </StackPane>

        <StackPane fx:id="uiLayer"
                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Canvas fx:id="cardCanvas" height="720.0" width="1280.0" />
            </children>
        </StackPane>

        <Button fx:id="apiButton" text="⚙  API 设置"
                AnchorPane.leftAnchor="28.0" AnchorPane.topAnchor="27.0"
                style="-fx-background-color: rgba(7,10,16,0.88); -fx-background-radius: 999; -fx-border-color: rgba(255,255,255,0.32); -fx-border-radius: 999; -fx-text-fill: rgba(255,255,255,0.94); -fx-font-family: 'Microsoft YaHei UI'; -fx-font-size: 12px; -fx-padding: 10 17 10 17; -fx-cursor: hand;" />

        <StackPane prefHeight="184.0" prefWidth="244.0" opacity="0.88"
                   style="-fx-background-color: rgba(0,0,0,0.82); -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.26); -fx-border-radius: 16; -fx-padding: 2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.65), 24, 0.12, 0, 8);"
                   AnchorPane.rightAnchor="26.0" AnchorPane.topAnchor="26.0">
            <children>
                <ImageView fx:id="cameraView" fitHeight="180.0" fitWidth="240.0"
                           preserveRatio="true" smooth="true" />
                <Label text="LIVE" StackPane.alignment="TOP_LEFT"
                       style="-fx-text-fill: white; -fx-background-color: rgba(0,0,0,0.58); -fx-background-radius: 8; -fx-font-size: 10px; -fx-padding: 5 8 5 8;">
                    <StackPane.margin>
                        <Insets left="9.0" top="9.0" />
                    </StackPane.margin>
                </Label>
            </children>
        </StackPane>
    </children>
</AnchorPane>
