<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/app.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gesturegame.ui.LobbyController"
            styleClass="lobby-root">
    <children>
        <Canvas fx:id="lobbyCanvas" width="1280.0" height="720.0"
                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

        <VBox alignment="TOP_CENTER" spacing="8.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="26.0">
            <children>
                <Label styleClass="lobby-title" text="AI Gesture Game Lobby" />
                <Label styleClass="lobby-subtitle" text="星河之中，挥手穿梭六颗游戏星球" />
            </children>
        </VBox>

        <VBox alignment="BOTTOM_CENTER" spacing="12.0"
              AnchorPane.bottomAnchor="26.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Label fx:id="statusLabel" styleClass="lobby-status"
                       text="左右挥手切换星球 · 握拳确认进入" wrapText="true" />
                <HBox alignment="CENTER" spacing="14.0">
                    <children>
                        <Label styleClass="hint-badge" text="SWIPE_LEFT" />
                        <Label styleClass="hint-badge" text="SWIPE_RIGHT" />
                        <Label styleClass="hint-badge" text="张手爆发" />
                        <Label styleClass="hint-badge" text="握拳确认" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <StackPane AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0"
                   maxHeight="180.0" maxWidth="240.0" minHeight="180.0" minWidth="240.0"
                   prefHeight="180.0" prefWidth="240.0" styleClass="camera-preview-panel">
            <children>
                <ImageView fx:id="cameraView" fitHeight="148.0" fitWidth="212.0" preserveRatio="true"
                           styleClass="camera-preview-image" />
                <Rectangle arcHeight="20.0" arcWidth="20.0" fill="TRANSPARENT"
                           height="148.0" mouseTransparent="true" stroke="#38bdf8"
                           strokeType="INSIDE" strokeWidth="1.4" width="212.0" />
                <Label StackPane.alignment="TOP_LEFT" styleClass="preview-title" text="LIVE FEED" />
            </children>
            <padding>
                <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
            </padding>
        </StackPane>
    </children>
</AnchorPane>
