<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>

<StackPane fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0"
           stylesheets="@../css/app.css"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.gesturegame.ui.LoginController"
           styleClass="splash-root">
    <children>
        <Canvas fx:id="starCanvas" width="1280.0" height="720.0" />
        <Label fx:id="enterLabel" text="ENTER" mouseTransparent="true"
               styleClass="splash-enter" />
    </children>
</StackPane>
